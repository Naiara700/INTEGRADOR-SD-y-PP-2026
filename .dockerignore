# ==========================================
# .dockerignore para Microservicios de StickerChain
# ==========================================

# 1. Versionamiento de Código y Configuración Git
.git
.gitmodules
.gitignore
.gitattributes

# 2. Archivos temporales y compilados de Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 3. Entornos Virtuales y Dependencias Locales
.venv/
venv/
ENV/
env/
pooling/
bin/
obj/

# 4. Configuración de Editores e IDEs (VS Code, PyCharm, etc.)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# 5. Archivos de pruebas y reportes
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.hypothesis/

# 6. Manifiestos de Docker/Kubernetes y logs locales
Dockerfile*
docker-compose*
k8s/
*.log

frontend/node_modules/
frontend/dist/
frontend/.next/
